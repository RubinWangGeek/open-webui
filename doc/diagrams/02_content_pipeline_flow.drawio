        <!-- ========== Step 3: ENRICH ========== -->
        <mxCell id="step3" value="Step 3: ENRICH — 元数据增强&#xa;&#xa;MetadataEnricher&#xa;• 生成 source_id (唯一标识)&#xa;• 提取主题标签 (topics)&#xa;• 关联 Skills (applicable_skills)&#xa;• 标注可信度 (credibility)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="710" width="260" height="130" as="geometry" />
        </mxCell>
        <mxCell id="enrich-output" value="EnrichedMetadata&#xa;{ source_id, topics,&#xa;  applicable_skills, ... }" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=0.25;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="660" y="740" width="220" height="55" as="geometry" />
        </mxCell>

        <mxCell id="s3a1" style="strokeColor=#666;" edge="1" source="step3" target="enrich-output" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== Step 4: CHUNK ========== -->
        <mxCell id="step4" value="Step 4: CHUNK — 文本切片&#xa;&#xa;TextChunker&#xa;• chunk_size: 500 字&#xa;• overlap: 50 字&#xa;• 在句号/换行处断开&#xa;• 生成 chunk_id: {source_id}#c{N}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="880" width="260" height="120" as="geometry" />
        </mxCell>

        <!-- ========== Step 5: EMBED ========== -->
        <mxCell id="step5" value="Step 5: EMBED — 向量化&#xa;&#xa;EmbeddingGenerator&#xa;• 模型: BAAI/bge-small-zh-v1.5&#xa;• L2 归一化&#xa;• batch_size: 32" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="520" y="880" width="240" height="120" as="geometry" />
