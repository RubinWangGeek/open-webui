        <mxCell id="ext-pdf" value="PDFExtractor&#xa;(pdfplumber)&#xa;&#xa;• 逐页提取文本&#xa;• 提取元数据(标题/作者/页数)&#xa;• 保留页码标记 [Page N]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E6;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="140" y="220" width="180" height="140" as="geometry" />
        </mxCell>
        <mxCell id="ext-text" value="TextExtractor&#xa;&#xa;• 直接读取 .txt/.md&#xa;• 提取文件元数据&#xa;• 检测编码" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E6;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="340" y="220" width="170" height="140" as="geometry" />
        </mxCell>
        <mxCell id="ext-audio" value="AudioExtractor&#xa;&#xa;→ WhisperTranscriber&#xa;&#xa;• 加载 faster-whisper 模型&#xa;• VAD 过滤静音段&#xa;• 返回文本 + 时间戳分段&#xa;• 自动语言检测" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E6;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=8;verticalAlign=top;spacingTop=5;fontColor=#333333;" vertex="1" parent="1">
