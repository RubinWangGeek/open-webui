        <mxCell id="step1-label" value="Step 1: EXTRACT — 提取原始文本" style="text;html=1;align=left;fontSize=14;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="140" y="185" width="350" height="25" as="geometry" />
