          <mxGeometry x="500" y="1095" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="store-vec2" value="🔍 vector/&#xa;Chroma 向量索引&#xa;(ChromaVectorStore)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="700" y="1095" width="150" height="70" as="geometry" />
