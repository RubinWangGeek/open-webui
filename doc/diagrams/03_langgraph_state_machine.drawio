        <mxCell id="e-selfcheck-cond" style="strokeColor=#333;strokeWidth=2;" edge="1" source="selfcheck" target="cond-retry" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 条件边: 重试 -->
        <mxCell id="e-retry" value="不合格 &amp; 次数 &lt; N" style="strokeColor=#b85450;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#333333;" edge="1" source="cond-retry" target="execute" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="420" y="835" />
              <mxPoint x="420" y="620" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 条件边: finalize -->
        <mxCell id="e-cond-finalize" value="合格 或 达到上限" style="strokeColor=#82b366;strokeWidth=2;fontStyle=1;fontSize=12;fontColor=#333333;" edge="1" source="cond-retry" target="finalize" parent="1">
          <mxGeometry relative="1" as="geometry" />
