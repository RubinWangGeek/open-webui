        <!-- 状态说明框 -->
        <mxCell id="state-box" value="AgentState 关键字段&#xa;─────────────────&#xa;thread_id, request_id&#xa;user_query, messages[]&#xa;intent, intent_detail&#xa;skill_plan[]&#xa;needs_askback, askback_questions[]&#xa;retrieval_results[]&#xa;skill_outputs[]&#xa;selfcheck_passed, selfcheck_count&#xa;final_markdown, final_citations[]&#xa;confidence, audit_log[]" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#ffffcc;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=8;verticalAlign=top;spacingTop=18;fontColor=#333333;" vertex="1" parent="1">
